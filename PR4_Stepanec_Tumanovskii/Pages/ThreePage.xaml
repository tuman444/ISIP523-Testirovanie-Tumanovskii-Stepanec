<Page x:Class="PR4_Stepanec_Tumanovskii.Pages.ThreePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR4_Stepanec_Tumanovskii.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ThreePage">

    <Grid Background="Pink">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <StackPanel Grid.Column="0" Background="Black" Orientation="Vertical">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0" HorizontalAlignment="Left">
                    <TextBlock Text="x" Margin="10" HorizontalAlignment="Left" Foreground="White" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Left" Margin="0,10" Grid.Column="1" Grid.Row="0">
                    <TextBox x:Name="XTextBox" Margin="10" Width="100"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="Ответ" Margin="10" Foreground="White"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBox x:Name="ResultTextBox" Margin="10" Width="100" IsReadOnly="True"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0">
                    <Button x:Name="CountBtn" Content="Вычислить" Padding="5" Margin="10" Background="Pink" Foreground="Black" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1">
                    <Button x:Name="CleanBtn" Content="Очистить" Margin="10" Padding="5" Background="Pink" Foreground="Black" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="BackBtn" Grid.Row="2" Content="Назад" Margin="10" Padding="5" Click="BackBtn_Click" Background="Pink" Foreground="Black" FontWeight="Bold" />
                    <Button x:Name="ExitBtn" Grid.Row="2" Content="Выйти" Margin="10" Padding="5" Click="ExitBtn_Click" Background="Pink" Foreground="Black" FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <Image Source="/Images/ThreeCaseImg.jpg" Grid.Column="1" Width="530" VerticalAlignment="Top" Margin="0,50"/>

    </Grid>
</Page>
